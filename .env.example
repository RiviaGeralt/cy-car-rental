# Vercel Blob Storage - Video Hosting
# Get your URL from: https://vercel.com/dashboard/stores?type=blob
# Format: https://<blob-store-id>.public.blob.vercel-storage.com/hero-video.mp4
NEXT_PUBLIC_BLOB_VIDEO_URL=https://your-blob-store-id.public.blob.vercel-storage.com/hero-video.mp4

# Optional: Vercel Blob API Token (for programmatic uploads via /api/upload-video.js)
# Only needed if using the upload API route
BLOB_READ_WRITE_TOKEN=your_token_here
